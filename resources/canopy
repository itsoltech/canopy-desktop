#!/bin/bash
# canopy — Canopy desktop CLI
case "$1" in
  skills)
    shift
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    exec "$SCRIPT_DIR/canopy-skills.sh" "$@"
    ;;
  *)
    echo "Usage: canopy <command>"
    echo ""
    echo "Commands:"
    echo "  skills    Manage agent skills"
    ;;
esac
