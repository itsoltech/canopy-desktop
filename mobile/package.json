{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "ios": "expo start --dev-client --ios",
    "android": "expo start --dev-client --android",
    "web": "expo start --web",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run lint",
    "doctor": "npx expo-doctor",
    "build:dev": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:sim": "eas build --profile development-simulator --platform ios",
    "build:prod": "eas build --profile production --platform ios",
    "build:prod:android": "eas build --profile production --platform android",
    "build:run:sim": "eas build:run --platform ios --latest",
    "builds:list": "eas build:list --limit 10",
    "update:dev": "node ./scripts/eas-update-publish.mjs development",
    "update:prod": "node ./scripts/eas-update-publish.mjs production",
    "device:create": "eas device:create",
    "device:list": "eas device:list",
    "credentials": "eas credentials",
    "config:dev": "NODE_ENV=development expo config --json",
    "config:prod": "NODE_ENV=production expo config --json"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@expo/ui": "~55.0.11",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "expo": "~55.0.15",
    "expo-camera": "~55.0.15",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.14",
    "expo-widgets": "^55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webrtc": "^124.0.7",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "volta": {
    "node": "22.20.0"
  }
}
