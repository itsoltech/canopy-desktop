{
  "name": "canopy",
  "version": "0.7.0-next.9",
  "description": "Developer terminal workstation",
  "main": "./out/main/index.js",
  "author": "ITSOL",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://canopy.itsol.tech",
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run svelte-check",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && generate-license-file -i package.json -o THIRD-PARTY-NOTICES --overwrite",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release": "npm run build && electron-builder --publish always",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@electron-toolkit/utils": "^4.0.0",
    "@lucide/svelte": "^1.0.0-rc.1",
    "@selemondev/svgl-svelte": "^2.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.3.9",
    "lucide-svelte": "^1.0.1",
    "marked": "^17.0.5",
    "node-pty": "^1.1.0",
    "semver": "^7.7.4",
    "simple-git": "^3.33.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.1",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.1",
    "generate-license-file": "^4.1.1",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "volta": {
    "node": "24.14.0"
  }
}
